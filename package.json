{
  "name": "twinpet-pos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "gen-config": "node scripts/gen-deploy-config.mjs",
    "predev": "npm run gen-config && npm --prefix functions run build",
    "dev": "node scripts/start-emulator.mjs",
    "dev:emulator": "node scripts/start-emulator.mjs",
    "free:ports": "node scripts/free-emulator-ports.mjs",
    "snapshot:dump": "node scripts/pos-db-snapshot.mjs dump",
    "snapshot:restore": "node scripts/pos-db-snapshot.mjs restore",
    "dev:web": "vite",
    "seed:emulator": "node scripts/seed-emulator.mjs",
    "prebuild": "npm run gen-config",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:rules": "firebase emulators:exec --only firestore --project demo-twinpet \"vitest run --config vitest.rules.config.ts\"",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "firebase": "^12.13.0",
    "flowbite-react": "^0.12.17",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "react-firebase-hooks": "^5.1.1",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
