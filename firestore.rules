rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Custom-claim helpers (set by verifyPinLogin Cloud Function) ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isStaff() {
      return isAuthenticated() && request.auth.token.staffId != null;
    }

    function staffId() {
      return request.auth.token.staffId;
    }

    // Null-safe "caller stamped their own staffId on this doc" check. Reading a
    // MISSING map property via dot/bracket notation HARD-ERRORS in rules
    // ("Property staffId is undefined on object."), which surfaces as a
    // PERMISSION_DENIED crash rather than a clean deny. `.get(key, default)`
    // returns the default instead, so this is safe even when the payload omits
    // staffId — e.g. the offline void merge (`requestPendingVoid`) writes only
    // the void fields + branchId/deviceId and may CREATE the asyncOrders doc.
    function stampedOwnStaffId(data) {
      return data.get('staffId', null) == staffId();
    }

    function role() {
      return request.auth.token.role;
    }

    // Granular permission keys stamped into the token by verifyPinLogin (e.g.
    // ['pos_sale','pos_void',...]). `.get('permissions', [])` is null-safe:
    // tokens minted BEFORE this rollout carry no permissions claim and resolve
    // to [] instead of hard-erroring.
    function tokenPerms() {
      return request.auth.token.get('permissions', []);
    }

    function hasPerm(p) {
      return isStaff() && (p in tokenPerms());
    }

    function branchIds() {
      return request.auth.token.branchIds;
    }

    function isAdmin() {
      return isStaff() && role() == 'admin';
    }

    function isManagerOrAdmin() {
      return isStaff() && role() in ['admin', 'manager'];
    }

    function hasBranchAccess(branchId) {
      // 'ALL' in the token's branchIds = global admin → access to every branch.
      // The app code (PosShellRoute / useBranch) already treats 'ALL' this way;
      // the rules must match, or global admins fail per-branch write checks.
      return isStaff() && ('ALL' in branchIds() || branchId in branchIds());
    }

    /**
     * A productStocks write must come from a STOCK-CAPABLE staffer, not a
     * pos_sale-only checkout terminal. Regular staff carry 'product_view' (so
     * staff-initiated branch transfers keep working, business decision #1); any
     * receiving/adjust/void/product role qualifies; admins always qualify.
     * Sales never reach here — POS checkout decrements stock server-side via the
     * reconcileOrder Cloud Function (Admin SDK), which bypasses these rules.
     */
    function canMutateStock() {
      return isAdmin()
        || 'stock_receive' in tokenPerms()
        || 'product_edit' in tokenPerms()
        || 'pos_void' in tokenPerms()
        || 'product_view' in tokenPerms();
    }

    function isGlobalSettingsId(settingId) {
      return settingId in ['system', 'expiryPolicies', '_rolePermissions'];
    }

    function canReadSettingsDoc(settingId) {
      return isStaff() && (isGlobalSettingsId(settingId) || hasBranchAccess(settingId));
    }

    function canWriteSettingsDoc(settingId) {
      return isAdmin() && (isGlobalSettingsId(settingId) || hasBranchAccess(settingId));
    }

    // ── Branches (login dropdown — any signed-in client incl. anonymous) ──
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Staff profiles ──
    match /users/{userId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ── Settings (global + per-branch) ──
    match /settings/{settingId} {
      // Admin reads any branch's settings (e.g. allowNegativeStock for cross-branch receiving)
      allow read: if isAdmin() || canReadSettingsDoc(settingId);
      allow write: if canWriteSettingsDoc(settingId);

      match /docCounters/{counterId} {
        allow read, write: if isStaff();
      }
    }

    // ── Global master data ──
    match /categories/{docId} {
      allow read: if isStaff();
      allow write: if isManagerOrAdmin();
    }

    match /customerTiers/{docId} {
      allow read: if isStaff();
      allow write: if isManagerOrAdmin();
    }

    match /priceLevels/{docId} {
      // Staff read all levels; the client merges global + their branch.
      allow read: if isStaff();
      // Global levels (branchId == null) are manager/admin managed; branch-scoped
      // levels additionally require access to that branch. Delete (request.resource
      // null) stays manager/admin gated.
      allow write: if isManagerOrAdmin()
        && (request.resource == null
            || request.resource.data.branchId == null
            || hasBranchAccess(request.resource.data.branchId));
    }

    match /uomUnits/{docId} {
      allow read: if isStaff();
      allow write: if isManagerOrAdmin();
    }

    // ── Catalog ──
    match /products/{productId} {
      allow read: if isStaff();
      allow write: if isManagerOrAdmin();
      // Admin-only — used by the Danger Zone hard-delete to wipe the product catalog
      allow delete: if isAdmin();

      match /productStocks/{stockBranchId} {
        allow read: if isAdmin() || hasBranchAccess(stockBranchId);
        // Phase 1 hardening:
        //  • branchId in the payload MUST equal the doc id → blocks branch-id
        //    spoofing (writing branch B's doc while stamping branchId "A").
        //  • writer must be stock-capable (canMutateStock) → blocks pos_sale-only
        //    cashiers from directly mutating stock.
        // Cross-branch destination writes for branch transfers stay allowed
        // (confirmBranchTransfer stamps branchId == toBranch == doc id), per
        // business decision #1. Full branch isolation of that dest leg is Phase 2
        // (move the cross-branch write to a Cloud Function) — NOT done here.
        // Sales never write here: POS checkout decrements via reconcileOrder
        // (Admin SDK), so oversell/negative stock is unaffected (decision #2).
        allow create, update: if isStaff()
          && request.resource.data.branchId == stockBranchId
          && canMutateStock();
        // Admin-only — explicit (NOT a broad `write`, so delete is not subsumed).
        allow delete: if isAdmin();
      }
    }

    // collectionGroup('productStocks') — query filters on resource.data.branchId
    match /{path=**}/productStocks/{stockDocId} {
      allow read: if isAdmin() || (isStaff()
        && resource.data.branchId is string
        && hasBranchAccess(resource.data.branchId));
      // Mirror the nested block exactly — rules grant on the UNION of matching
      // blocks, so leaving this permissive would re-open the writes hardened above.
      allow create, update: if isStaff()
        && request.resource.data.branchId == stockDocId
        && canMutateStock();
      // Admin-only — explicit delete for the Danger Zone hard-delete collectionGroup sweep
      allow delete: if isAdmin();
    }

    // ── Suppliers (centralized catalog — HQ manages all; branches can add local ones) ──
    match /suppliers/{supplierId} {
      // Admin: full access
      allow read, write: if isAdmin();
      // Admin-only — explicit delete for the Danger Zone hard-delete of suppliers
      allow delete: if isAdmin();

      // Staff: read when supplier is visible to their branch
      allow read: if isStaff()
        && resource.data.isActive == true
        && (
          resource.data.allowedBranchIds.hasAny(['ALL'])
          || resource.data.allowedBranchIds.hasAny(branchIds())
        );

      // Staff: create a new supplier when their own branchId is in the new doc's allowedBranchIds
      // (POS staff can only create branch-local suppliers, not global ones)
      allow create: if isStaff()
        && request.resource.data.allowedBranchIds is list
        && request.resource.data.allowedBranchIds.hasAny(branchIds())
        && !request.resource.data.allowedBranchIds.hasAny(['ALL']);

      // Staff: update a supplier that is already visible to (i.e. owned by) their branch
      allow update: if isStaff()
        && (
          resource.data.allowedBranchIds.hasAny(branchIds())
        )
        // Cannot escalate to ALL-branches visibility
        && !request.resource.data.allowedBranchIds.hasAny(['ALL']);
    }

    // ── Customers & credit ──
    match /customers/{customerId} {
      allow read: if isStaff();
      allow write: if isStaff();
      // Admin-only — used by the Danger Zone hard-delete of customer master data
      allow delete: if isAdmin();
    }

    match /creditAccounts/{accountId} {
      allow read: if isStaff();
      allow write: if isStaff();
      // Admin-only — used by the Danger Zone hard-delete of customer master data
      allow delete: if isAdmin();
    }

    match /creditTransactions/{txId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isManagerOrAdmin();
      // Admin-only — used by the Danger Zone UAT reset to wipe credit history
      allow delete: if isAdmin();
    }

    match /creditPayments/{paymentId} {
      allow read: if isStaff();
      allow create: if isStaff();
      // Admin-only — used by the Danger Zone UAT reset to wipe credit history
      allow delete: if isAdmin();
    }

    // ── Async sales (offline-first checkout "intent" inbox) ──
    // The client writes the sale here with a single queueable setDoc (offline-safe).
    // The reconcileOrder Cloud Function (Admin SDK — bypasses these rules) settles
    // it and dual-writes the canonical `orders`. Checkout needs `pos_sale`;
    // void-intent (create or update) needs `pos_void`.
    match /asyncOrders/{orderId} {
      allow read: if isAdmin() || (isStaff() && hasBranchAccess(resource.data.branchId));
      // A normal checkout stamps the caller's own staffId. The offline void merge
      // (`requestPendingVoid`) is a queueable setDoc(merge) that may MATERIALISE a
      // not-yet-cached doc — a create whose payload carries no staffId. Permit
      // that path when it is a `pos_void` void-intent (`voidRequested == true`),
      // mirroring the `pos_void` gate on the update path below.
      allow create: if hasBranchAccess(request.resource.data.branchId)
        && (
          (hasPerm('pos_sale') && stampedOwnStaffId(request.resource.data))
          || (hasPerm('pos_void')
            && request.resource.data.get('voidRequested', false) == true)
        );
      allow update: if hasPerm('pos_void')
        && hasBranchAccess(resource.data.branchId);
      allow delete: if isAdmin();
    }

    // ── Sales ──
    match /orders/{orderId} {
      allow read: if isAdmin() || (isStaff() && hasBranchAccess(resource.data.branchId));
      allow create: if hasPerm('pos_sale')
        && hasBranchAccess(request.resource.data.branchId)
        && stampedOwnStaffId(request.resource.data);
      allow update: if hasPerm('pos_void')
        && hasBranchAccess(resource.data.branchId);
      // Admin-only — used by the Danger Zone UAT reset to wipe sales history
      allow delete: if isAdmin();

      match /orderItems/{itemId} {
        allow read: if isStaff();
        // Parent order may be created in the same batch — cannot get() it yet
        allow create: if isStaff();
        allow update, delete: if isAdmin() || (isStaff()
          && hasBranchAccess(get(/databases/$(database)/documents/orders/$(orderId)).data.branchId));
      }
    }

    match /payments/{paymentId} {
      allow read: if isStaff();
      allow create: if isStaff();
      // Admin-only — used by the Danger Zone UAT reset to wipe sales history
      allow delete: if isAdmin();
    }

    match /parkedOrders/{parkedId} {
      allow read: if isStaff() && hasBranchAccess(resource.data.branchId);
      allow write: if isStaff() && hasBranchAccess(request.resource.data.branchId);

      match /parkedItems/{itemId} {
        allow read: if isStaff();
        allow create: if isStaff();
        allow update, delete: if isStaff()
          && hasBranchAccess(get(/databases/$(database)/documents/parkedOrders/$(parkedId)).data.branchId);
      }
    }

    match /quotations/{quotationId} {
      allow read: if isStaff() && hasBranchAccess(resource.data.branchId);
      allow write: if isStaff() && hasBranchAccess(request.resource.data.branchId);

      match /quotationItems/{itemId} {
        allow read: if isStaff();
        allow create: if isStaff();
        allow update, delete: if isStaff()
          && hasBranchAccess(get(/databases/$(database)/documents/quotations/$(quotationId)).data.branchId);
      }
    }

    // ── Inventory ──
    match /stockLots/{lotId} {
      // READ unchanged (Phase 2 Track A): any staff may read lots — preserves
      // cross-branch visibility, transfer planning, and aggregate reporting.
      allow read: if isStaff();
      // Lots are created by receiving, positive adjustments (ADJUST_IN), the
      // destination side of branch transfers, and oversell reconciliation.
      // Phase 2 Track A hardening: writer must be stock-capable (canMutateStock)
      // — this blocks pos_sale-only cashiers from fabricating/rewriting lot
      // qty/cost. A transfer still creates a lot in the DESTINATION branch, so we
      // intentionally do NOT require destination-branch access here (staff
      // transfers preserved); branch isolation of that leg is a later phase.
      // Create additionally requires a declared branchId (every real lot has one).
      allow create: if isStaff() && canMutateStock()
        && request.resource.data.branchId is string;
      allow update: if isStaff() && canMutateStock();
      allow delete: if isManagerOrAdmin();
    }

    match /stockMovements/{movementId} {
      allow read: if isStaff();
      // Own-branch movements (sale, receive, adjust, transfer_out) require branch
      // access. The transfer_in leg writes to the DESTINATION branch, so allow
      // movements tagged refType 'inventoryTransfer' to be created cross-branch.
      allow create: if isAdmin() || (isStaff()
        && (hasBranchAccess(request.resource.data.branchId)
          || request.resource.data.refType == 'inventoryTransfer'));
      // Managers/admins can update or delete movements when editing a confirmed receiving
      allow update, delete: if isAdmin() || (isManagerOrAdmin()
        && hasBranchAccess(resource.data.branchId));
    }

    match /receivings/{receivingId} {
      // Admin reads all receivings across every branch (HQ cross-branch visibility)
      allow read: if isAdmin() || (isStaff() && hasBranchAccess(resource.data.branchId));
      // Admin creates receivings for any branch (HQ cross-branch receiving creation)
      allow create: if isAdmin() || (isManagerOrAdmin() && hasBranchAccess(request.resource.data.branchId));
      // Admin updates any receiving (e.g. fixing supplierId); managers can update within their branch
      allow update: if isAdmin() || (isManagerOrAdmin() && hasBranchAccess(resource.data.branchId) && hasBranchAccess(request.resource.data.branchId));
      allow delete: if isAdmin() || (isManagerOrAdmin() && hasBranchAccess(resource.data.branchId));

      match /receivingItems/{itemId} {
        allow read: if isStaff();
        allow create: if isStaff();
        // Admin deletes items when finalizing a cross-branch draft
        allow update, delete: if isAdmin() || (isStaff()
          && hasBranchAccess(get(/databases/$(database)/documents/receivings/$(receivingId)).data.branchId));
      }
    }

    match /inventoryAdjustments/{adjustmentId} {
      allow read: if isAdmin() || (isStaff() && hasBranchAccess(resource.data.branchId));
      allow write: if isAdmin() || (isStaff() && hasBranchAccess(request.resource.data.branchId));

      match /adjustmentItems/{itemId} {
        allow read: if isStaff();
        allow create: if isStaff();
        allow update, delete: if isAdmin() || (isStaff()
          && hasBranchAccess(get(/databases/$(database)/documents/inventoryAdjustments/$(adjustmentId)).data.branchId));
      }
    }

    match /inventoryTransfers/{transferId} {
      allow read: if isAdmin() || (isStaff()
        && (hasBranchAccess(resource.data.fromBranchId)
          || hasBranchAccess(resource.data.toBranchId)));
      // Admin (incl. global 'ALL') or a staff member at the SOURCE branch.
      allow write: if isAdmin()
        || (isStaff() && hasBranchAccess(request.resource.data.fromBranchId));

      match /transferItems/{itemId} {
        allow read: if isStaff();
        allow create: if isStaff();
        allow update, delete: if isAdmin() || (isStaff()
          && hasBranchAccess(get(/databases/$(database)/documents/inventoryTransfers/$(transferId)).data.fromBranchId));
      }
    }

    // ── Shifts & cash ──
    match /shifts/{shiftId} {
      allow read: if isStaff() && hasBranchAccess(resource.data.branchId);
      allow create: if isStaff()
        && hasBranchAccess(request.resource.data.branchId);
      allow update: if isStaff()
        && hasBranchAccess(resource.data.branchId);
      // Admin-only — used by the Danger Zone UAT reset to wipe shift history
      allow delete: if isAdmin();
    }

    match /cashTransactions/{txId} {
      allow read: if isStaff() && hasBranchAccess(resource.data.branchId);
      allow create: if isStaff()
        && hasBranchAccess(request.resource.data.branchId);
      // Admin-only — used by the Danger Zone UAT reset to wipe cash history
      allow delete: if isAdmin();
    }

    match /posDevices/{deviceId} {
      allow read: if isStaff() && hasBranchAccess(resource.data.branchId);
      // Managers/admins register & label their branch's terminals (Settings → POS Devices).
      allow write: if isManagerOrAdmin() && hasBranchAccess(request.resource.data.branchId);
    }

    // ── Staff activity & audit ──
    match /staffActivities/{activityId} {
      allow read: if isStaff();
      allow create: if isStaff();
      // Admin-only — used by the Danger Zone UAT reset to wipe activity logs
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isStaff();
      // Admin-only — used by the Danger Zone UAT reset to wipe audit logs
      allow delete: if isAdmin();
    }

    // ── POS sync signal (admin "ring the bell" → branch POS terminals pull) ──
    // pos_configs/branches/{branchId}/sync_state — a single tiny doc per branch
    // holding lastForceUpdate. Staff on the branch read it (POS listener);
    // managers/admins with branch access write it (broadcast).
    match /pos_configs/branches/{branchId}/sync_state {
      allow read: if isStaff() && hasBranchAccess(branchId);
      allow write: if isManagerOrAdmin() && hasBranchAccess(branchId);
    }

    // Sharded POS product ordering — one doc per (branch, categoryKey) holding
    // { order: string[], rev, updatedAt }. POS staff read it for the grid;
    // managers/admins with branch access write it from the Sorting editor.
    match /pos_configs/branches/{branchId}/sorting/categories/{categoryKey} {
      allow read: if isStaff() && hasBranchAccess(branchId);
      allow write: if isManagerOrAdmin() && hasBranchAccess(branchId);
    }

    // Quick Menus (virtual categories) — one doc per branch holding the menus
    // array. POS staff read them; managers/admins with branch access edit them.
    match /pos_configs/branches/{branchId}/quick_menus {
      allow read: if isStaff() && hasBranchAccess(branchId);
      allow write: if isManagerOrAdmin() && hasBranchAccess(branchId);
    }

    // ── Default deny for unlisted collections ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
