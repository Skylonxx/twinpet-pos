VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Set to true to point ALL Firebase SDKs (Firestore, Auth, Storage, Functions) at
# the LOCAL emulator suite — the true local loop (browser → local DB → local
# Functions trigger). Put this in .env.local. Leave false/unset to use the cloud.
# Requires the Java JDK (the Firestore emulator needs it) + `npm run dev`.
VITE_USE_EMULATOR=false
# When off in dev, the dev server proxies /__/firebase/functions/* to Cloud Functions.

# ── Deployment config (DO NOT set by hand) ───────────────────────────────────
# These are AUTO-GENERATED into .env from firebase.json (firestore.database /
# firestore.location) by scripts/gen-deploy-config.mjs on every dev/build.
# firebase.json is the single source of truth — change them there.
# VITE_FIRESTORE_DATABASE_ID=pos-db
# VITE_FUNCTIONS_REGION=asia-southeast1
