VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Set to true when using firebase emulators for local PIN login testing
VITE_USE_FUNCTIONS_EMULATOR=false
# Dev server proxies /__/firebase/functions/* to Cloud Functions (avoids CORS on localhost)

# ── Deployment config (DO NOT set by hand) ───────────────────────────────────
# These are AUTO-GENERATED into .env from firebase.json (firestore.database /
# firestore.location) by scripts/gen-deploy-config.mjs on every dev/build.
# firebase.json is the single source of truth — change them there.
# VITE_FIRESTORE_DATABASE_ID=pos-db
# VITE_FUNCTIONS_REGION=asia-southeast1
