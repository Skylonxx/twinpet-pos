rules_version = '2';

// Baseline Storage rules — added so the Storage EMULATOR can boot (firebase.json
// → storage). Authenticated read/write only (the app signs in via Firebase Auth,
// so request.auth is set). REVIEW/tighten before any production storage deploy.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
