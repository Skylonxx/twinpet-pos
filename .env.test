# ── E2E / Playwright test mode ───────────────────────────────────────────────
# Vite priority (high → low): .env.[mode].local > .env.[mode] > .env.local > .env
# This file (.env.test) therefore overrides .env.local when Vite is started
# with `--mode test`.  All Firebase vars are explicitly blanked so that
# `isFirebaseConfigured` evaluates to false and every data hook falls back to
# the deterministic dev-mock layer.  Tests NEVER touch the real database.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
